defaults:
  recent_n: 5
  language_hint: zh
  quality_l3_enabled: true
  paths:
    archive_root: ~/Knowledge/broadcast/archive
    state_dir: ~/Knowledge/broadcast/state
    log_dir: ~/Knowledge/broadcast/logs
  transcribe:
    parallelism: 1               # safe default; bump to 2 only when system has free RAM
    batch_size: 8                # decoder batch size for BatchedInferencePipeline
    convert_traditional: true    # zh-Hant -> zh-Hans via opencc
    min_avail_gb_per_worker: 1.5  # auto-降档 if RAM is tighter
  lark_folder_token: "<your folder token>"   # 飞书云文档文件夹 token (or set LARK_FOLDER_TOKEN env)

feeds:
  # Replace these with real feeds.
  - name: Example Xiaoyuzhou Show
    rss_url: https://example.xiaoyuzhou.fm/rss
    source: xiaoyuzhou
    language: zh
    enabled: true
    wiki_node_token: <show subnode token>     # 该节目在 wiki 里的子节点 token;留空则用 lark_wiki_root_token 兜底
