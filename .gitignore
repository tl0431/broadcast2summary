# Secrets — sourced from ~/.bashrc_claude, never commit
.env
.env.*
!.env.example
config/.env
secrets.*

# Runtime state and outputs
state/
archive/
logs/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# OS / editor
.DS_Store
.idea/
.vscode/

# Memory plugin scratch
.remember/logs/
.remember/tmp/

# User's real subscriptions — local only; commit feeds.yaml.example as the template
config/feeds.yaml
!config/feeds.yaml.example

# E2e Lark targets (wiki node token for isolated Feishu testing)
config/e2e.yaml
!config/e2e.yaml.example

# Generated docs (keep source .md)
docs/superpowers/specs/*.html
docs/superpowers/plans/*.html
scripts/translate_playground.html
